import type { ThemeId } from "@shared/types";
import { create } from "zustand";
import { DEFAULT_THEME_ID, getThemeById, type ThemeDefinition } from "../themes";

export function applyThemeToElement(theme: ThemeDefinition, element: HTMLElement): void {
  for (const [key, value] of Object.entries(theme.colors)) {
    element.style.setProperty(`--color-${key}`, value);
  }
  element.style.setProperty("color-scheme", theme.mode);
}

interface ThemeState {
  activeThemeId: ThemeId;
  settingsOpen: boolean;
  mistralApiKeyDialogOpen: boolean;

  toggleSettings: () => void;
  closeSettings: () => void;
  setTheme: (id: ThemeId) => void;
  loadTheme: () => Promise<void>;
  openMistralApiKeyDialog: () => void;
  closeMistralApiKeyDialog: () => void;
}

export const useThemeStore = create<ThemeState>((set) => ({
  activeThemeId: DEFAULT_THEME_ID,
  settingsOpen: false,

  toggleSettings: () => {
    set((state) => ({ settingsOpen: !state.settingsOpen }));
  },

  closeSettings: () => {
    set({ settingsOpen: false });
  },

  setTheme: (id) => {
    set({ activeThemeId: id });
    const theme = getThemeById(id);
    if (typeof window !== "undefined" && window.document) {
      applyThemeToElement(theme, window.document.documentElement);
    }
    if (window.electronAPI) {
      window.electronAPI.saveSettings({ theme: id });
    }
  },

  loadTheme: async () => {
    if (!window.electronAPI) return;
    const settings = await window.electronAPI.getSettings();
    const themeId = settings.theme ?? DEFAULT_THEME_ID;
    set({ activeThemeId: themeId });
    const theme = getThemeById(themeId);
    if (typeof window !== "undefined" && window.document) {
      applyThemeToElement(theme, window.document.documentElement);
    }
  },
}));
