---
const base = import.meta.env.BASE_URL;
---

<section id="preview">
  <div class="container">
    <div class="preview-window">
      <div class="preview-titlebar">
        <div class="traffic-lights">
          <span class="dot red" />
          <span class="dot yellow" />
          <span class="dot green" />
        </div>
        <span class="titlebar-text">Codez</span>
      </div>
      <img
        src={`${base}/screenshots/app.png`}
        alt="Codez app showing parallel AI coding sessions"
        class="preview-img"
        width="1200"
        height="800"
      />
    </div>
  </div>
</section>

<style>
  #preview {
    padding: 0 24px 80px;
  }

  .preview-window {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 16px 64px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.06);
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .preview-titlebar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: var(--surface-hover);
    border-bottom: 1px solid var(--border-subtle);
  }

  .traffic-lights {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #FF5F57; }
  .dot.yellow { background: #FFBD2E; }
  .dot.green { background: #28CA41; }

  .titlebar-text {
    font-size: 0.8rem;
    color: var(--text-muted);
    flex: 1;
    text-align: center;
    margin-right: 54px;
  }

  .preview-img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 768px) {
    #preview {
      padding: 0 16px 56px;
    }
  }
</style>
